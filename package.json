{
  "name": "@workspace/ghostplay",
  "version": "0.2.0",
  "description": "Browser game test runner untuk AI agent — terintegrasi langsung di workspace, Chromium sudah terpasang",
  "private": true,
  "type": "module",
  "bin": {
    "ghostplay": "./src/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "install-browsers": "playwright install chromium",
    "run:scenario": "tsx src/cli.ts run",
    "watch:scenario": "tsx src/cli.ts watch",
    "example": "tsx src/cli.ts run scenarios/example.json"
  },
  "dependencies": {
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
